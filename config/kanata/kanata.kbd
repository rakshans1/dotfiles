;; Kanata config — Hyper removed, sublayers via letter-hold
;;
;; Layout:
;;   Caps Lock         → Escape
;;   Space tap         → space; Space hold → sys layer (apps + tmux)
;;   Home-row mods (left): a=Cmd  s=Opt  d=Ctrl  f=Shift
;;     f hold also enters shift-nav layer (tmux window switch)
;;
;;   Letter-hold sublayers (tap = letter, hold = enter sublayer):
;;     b hold → arc-bookmarks   (t=x c=claude e=mail g=github s=slack m=m.localhost r=reddit 1/2/3=spaces)
;;     n hold → obsidian-notes  (d=daily w=weekly m=monthly p=pin [=toggle)
;;     r hold → raycast         (c=camera p=confetti q=quicklinks)
;;     v hold → cursor          (g=Shift+Ctrl+G f=Shift+Opt+F s=Shift+Cmd+O p=Shift+Cmd+P)
;;     y hold → youtube         (h=history)

(defcfg
  process-unmapped-keys yes
  danger-enable-cmd yes
)

(defvar
  tap-time 200
  hold-time 180

  left-hand-keys (
    q w e r t
    a s d f g
    z x c v b
  )
  right-hand-keys (
    y u i o p
    h j k l ;
    n m , . /
  )
)

(defsrc
  q    w    e    r    t    y    u    i    o    p    [
  a    s    d    f    g    h    j    k    l    ;    '
  z    x    c    v    b    n    m
  1    2    3
  caps spc
)

(defalias
  ;; Caps Lock → Escape
  cap esc

  ;; Space: tap=space, hold=sys layer
  spcsys (tap-hold $tap-time $hold-time spc (layer-while-held sys))

  ;; ───────── Home-row mods (left only) ─────────
  hma (tap-hold-release-keys $tap-time $hold-time a lmet $left-hand-keys)
  hms (tap-hold-release-keys $tap-time $hold-time s lalt $left-hand-keys)
  hmd (tap-hold-release-keys $tap-time $hold-time d lctl $left-hand-keys)
  hmf (tap-hold-release-keys $tap-time $hold-time f (multi lsft (layer-while-held shift-nav)) $left-hand-keys)

  ;; ───────── Letter-hold sublayer triggers ─────────
  lb (tap-hold $tap-time $hold-time b (layer-while-held arc))
  ln (tap-hold $tap-time $hold-time n (layer-while-held notes))
  lr (tap-hold $tap-time $hold-time r (layer-while-held raycast))
  lv (tap-hold $tap-time $hold-time v (layer-while-held cursor))
  ly (tap-hold $tap-time $hold-time y (layer-while-held youtube))
  lt (tap-hold $tap-time $hold-time t (layer-while-held tmux-switch))

  ;; ───────── App launchers (sys layer) ─────────
  ap-arc      (cmd open -a "Arc.app")
  ap-chrome   (cmd open -a "Google Chrome.app")
  ap-cursor   (cmd open -a "Cursor.app")
  ap-obsidian (cmd open -a "Obsidian.app")
  ap-discord  (cmd open -a "Discord.app")
  ap-whatsapp (cmd open -a "WhatsApp.app")
  ap-ytmusic  (cmd open -a "Youtube Music.app")
  ap-sublime  (cmd open -a "Sublime Text.app")
  ap-raycast  (cmd open -a "Raycast.app")
  ap-youtube  (cmd /Users/rakshan/dotfiles/bin/open-link "https://www.youtube.com")
  ap-ghostty  (cmd open -a "Ghostty.app")

  ;; ───────── tmux switches ─────────
  tmw (cmd /usr/bin/sudo -u rakshan /Users/rakshan/.nix-profile/bin/tmux switch-client -t work)
  tmp (cmd /usr/bin/sudo -u rakshan /Users/rakshan/.nix-profile/bin/tmux switch-client -t projects)
  tms (cmd /usr/bin/sudo -u rakshan /Users/rakshan/.nix-profile/bin/tmux switch-client -t personal)

  ;; ───────── Arc bookmarks (b-hold sublayer) ─────────
  arx (cmd /Users/rakshan/dotfiles/bin/open-link-arc "https://x.com" "true")
  arc (cmd /Users/rakshan/dotfiles/bin/open-link-arc "https://claude.ai" "true")
  are (cmd /Users/rakshan/dotfiles/bin/open-link-arc "https://mail.google.com" "true")
  arg (cmd /Users/rakshan/dotfiles/bin/open-link-arc "https://github.com" "false")
  ars (cmd /Users/rakshan/dotfiles/bin/open-link-arc "https://app.slack.com/client/TNJRQ2H0E" "true")
  arm (cmd /Users/rakshan/dotfiles/bin/open-link-arc "https://m.localhost" "true")
  arr (cmd /Users/rakshan/dotfiles/bin/open-link-arc "https://www.reddit.com" "true")
  asw (cmd /Users/rakshan/dotfiles/bin/open-arc-space Work)
  asp (cmd /Users/rakshan/dotfiles/bin/open-arc-space Personal)
  asred (cmd /Users/rakshan/dotfiles/bin/open-arc-space Reading)

  ;; ───────── Obsidian notes (n-hold sublayer) ─────────
  rod (cmd /Users/rakshan/dotfiles/bin/rr o daily)
  row (cmd /Users/rakshan/dotfiles/bin/rr o weekly)
  rom (cmd /Users/rakshan/dotfiles/bin/rr o monthly)
  rop (cmd /Users/rakshan/dotfiles/bin/rr o pin)
  rot (cmd /Users/rakshan/dotfiles/bin/rr o toggle)

  ;; ───────── Raycast (r-hold sublayer) ─────────
  rcam   (cmd open "raycast://extensions/raycast/system/open-camera")
  rconf  (cmd open "raycast://extensions/raycast/raycast/confetti")
  rql    (cmd open "raycast://extensions/raycast/raycast/search-quicklinks")

  ;; ───────── YouTube history (y-hold sublayer) ─────────
  yth (cmd /Users/rakshan/dotfiles/bin/open-link "https://www.youtube.com/feed/history")
)

;; ═══════════════════════════════════════════════════════════════════
;; BASE LAYER
;; ═══════════════════════════════════════════════════════════════════
(deflayer base
  q    w    e    @lr  @lt  @ly  u    i    o    p    [
  @hma @hms @hmd @hmf g    h    j    k    l    ;    '
  z    x    c    @lv  @lb  @ln  m
  1    2    3
  @cap @spcsys
)

;; ═══════════════════════════════════════════════════════════════════
;; SYS LAYER — Space held (apps + tmux switches)
;; ═══════════════════════════════════════════════════════════════════
(deflayer sys
  _    @ap-whatsapp @ap-sublime @ap-raycast @ap-ghostty @ap-youtube _ _ _ _ _
  _    _            _           _           @ap-chrome  lft         down up   rght _ _
  _    _            _           @ap-cursor  @ap-arc     @ap-obsidian @ap-ytmusic
  _    _            _
  _    _
)

;; ═══════════════════════════════════════════════════════════════════
;; TMUX-SWITCH LAYER — t held
;;   j=work  k=projects  l=personal
;; ═══════════════════════════════════════════════════════════════════
(deflayer tmux-switch
  _    _    _    _    _    _    _    _    _    _    _
  _    _    _    _    _    _    @tmw @tmp @tms _    _
  _    _    _    _    _    _    _
  _    _    _
  _    _
)

;; ═══════════════════════════════════════════════════════════════════
;; SHIFT-NAV LAYER — f held (Shift active)
;;   h → Shift+Left   l → Shift+Right
;; ═══════════════════════════════════════════════════════════════════
(deflayer shift-nav
  _    _    _    _    _    _    _    _    _    _    _
  _    _    _    _    _    lft  _    _    rght _    _
  _    _    _    _    _    _    _
  _    _    _
  _    _
)

;; ═══════════════════════════════════════════════════════════════════
;; ARC SUBLAYER — b held
;;   t=x  c=claude  e=mail  g=github  s=slack  m=m.localhost  r=reddit
;;   1=Work space   2=Personal space   3=Reading space
;; ═══════════════════════════════════════════════════════════════════
(deflayer arc
  _    _    @are @arr @arx _    _    _    _    _    _
  _    @ars _    _    @arg _    _    _    _    _    _
  _    _    @arc _    _    _    @arm
  @asw @asp @asred
  _    _
)

;; ═══════════════════════════════════════════════════════════════════
;; NOTES SUBLAYER — n held
;;   d=daily  w=weekly  m=monthly  p=pin  [=toggle
;; ═══════════════════════════════════════════════════════════════════
(deflayer notes
  _    @row _    _    _    _    _    _    _    @rop @rot
  _    _    @rod _    _    _    _    _    _    _    _
  _    _    _    _    _    _    @rom
  _    _    _
  _    _
)

;; ═══════════════════════════════════════════════════════════════════
;; RAYCAST SUBLAYER — r held
;;   c=camera  p=confetti  q=quicklinks
;; ═══════════════════════════════════════════════════════════════════
(deflayer raycast
  @rql _    _    _    _    _    _    _    _    @rconf _
  _    _    _    _    _    _    _    _    _    _    _
  _    _    @rcam _    _    _    _
  _    _    _
  _    _
)

;; ═══════════════════════════════════════════════════════════════════
;; CURSOR SUBLAYER — v held
;;   g=Shift+Ctrl+G  f=Shift+Opt+F  s=Shift+Cmd+O  p=Shift+Cmd+P
;; ═══════════════════════════════════════════════════════════════════
(deflayer cursor
  _    _    _    _    _    _    _    _    _    S-M-p _
  _    S-M-o _    S-A-f S-C-g _    _    _    _    _    _
  _    _    _    _    _    _    _
  _    _    _
  _    _
)

;; ═══════════════════════════════════════════════════════════════════
;; YOUTUBE SUBLAYER — y held
;;   h=history
;; ═══════════════════════════════════════════════════════════════════
(deflayer youtube
  _    _    _    _    _    _    _    _    _    _    _
  _    _    _    _    _    @yth _    _    _    _    _
  _    _    _    _    _    _    _
  _    _    _
  _    _
)
